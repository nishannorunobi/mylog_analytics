
# Python
.venv/
__pycache__/
*.pyc
*.pyo

# Agent secrets and runtime state
log-agent/agent.conf
log-agent/memory/

# Downloaded tool binaries (regenerable via each tool's download_binary.sh)
log-agent/tools/*/download/
# Extracted tool source trees (regenerable via download_src.sh)
log-agent/tools/*/loki-*/
log-agent/tools/*/grafana-*/
log-agent/tools/*/alloy-*/

# Never track log files
*.log
